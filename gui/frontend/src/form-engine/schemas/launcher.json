          "label": "Broadcast Battle Server"
        },
        {
          "id": "launcherIsolateMetadata",
          "fieldKey": "launcher.Config.IsolateMetadata",
          "label": "Isolate Metadata"
        },
        {
          "id": "launcherIsolateProfiles",
          "fieldKey": "launcher.Config.IsolateProfiles",
          "label": "Isolate Profiles"
        },
        {
          "id": "launcherSetupCommand",
          "fieldKey": "launcher.Config.SetupCommand",
          "label": "Setup Command"
        },
        {
          "id": "launcherRevertCommand",
          "fieldKey": "launcher.Config.RevertCommand",
          "label": "Revert Command"
        }
