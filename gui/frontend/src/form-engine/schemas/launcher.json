          "fieldKey": "launcher.Config.Log",
          "label": "Enable Log"
        },
        {
          "id": "launcherCanAddHost",
          "fieldKey": "launcher.Config.CanAddHost",
          "label": "Allow Hosts Mapping"
        },
        {
          "id": "launcherCanTrustInPc",
          "fieldKey": "launcher.Config.Certificate.CanTrustInPc",
          "label": "Trust Certificate In OS"
        },
        {
          "id": "launcherCanBroadcastBattleServer",
