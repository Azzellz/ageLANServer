{
  "schemaVersion": "1.0",
  "formId": "launcher",
  "title": "Launcher Command Builder",
  "description": "Build launcher cobra-compatible arguments and sync related config values before execution.",
  "commandPath": [],
  "previewLabel": "Cobra Flags Preview",
  "sections": [
    {
      "id": "config_only",
      "title": "Config File Only",
      "description": "These values are written to the config file and are not emitted as CLI flags.",
      "columns": 2,
      "fields": [
        {
          "id": "launcherCanTrustInGame",
          "fieldKey": "launcher.Config.Certificate.CanTrustInGame",
          "label": "Trust Certificate In Game Store"
        },
        {
          "id": "launcherServerStartWithoutConfirmation",
          "fieldKey": "launcher.Server.StartWithoutConfirmation",
          "label": "Start Server Without Confirmation"
        },
        {
          "id": "launcherBattleServerManagerRun",
          "fieldKey": "launcher.Server.BattleServerManager.Run",
          "label": "Battle Server Manager Run Policy"
        },
        {
          "id": "launcherBattleServerManagerExecutable",
          "fieldKey": "launcher.Server.BattleServerManager.Executable",
          "label": "Battle Server Manager Executable"
        },
        {
          "id": "launcherBattleServerManagerExecutableArgs",
          "fieldKey": "launcher.Server.BattleServerManager.ExecutableArgs",
          "label": "Battle Server Manager Executable Args"
        },
        {
          "id": "launcherClientPath",
          "fieldKey": "launcher.Client.Path",
          "label": "Client Install Path"
        }
      ]
    },
    {
      "id": "runtime",
      "title": "Runtime",
      "description": "Runtime entry flags and config file selection.",
      "columns": 2,
      "fields": [
        {
          "id": "launcherGame",
          "fieldKey": "launcher.cli.--game",
          "label": "Game",
          "required": true,
          "serialization": {
            "flag": "--game",
            "mode": "single",
            "emitWhen": "non_empty"
          }
        },
        {
          "id": "launcherConfig",
          "fieldKey": "launcher.cli.--config",
          "label": "Main Config File",
          "serialization": {
            "flag": "--config",
            "mode": "single",
            "emitWhen": "non_empty"
          }
        },
        {
          "id": "launcherGameConfig",
          "fieldKey": "launcher.cli.--gameConfig",
          "label": "Game Config File",
          "serialization": {
            "flag": "--gameConfig",
            "mode": "single",
            "emitWhen": "non_empty"
          }
        }
      ]
    },
    {
      "id": "launcher_behavior",
      "title": "Launcher Behavior",
      "description": "Launcher-level isolation, certificate, and setup/revert behavior.",
      "columns": 2,
      "fields": [
        {
